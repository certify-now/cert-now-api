# ── Database ──────────────────────────────────────────────────────────────────
JDBC_DATABASE_URL=jdbc:postgresql://localhost:5433/cert-now-api
JDBC_DATABASE_USERNAME=postgres
JDBC_DATABASE_PASSWORD=changeme

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-random-64+-byte-secret-key-for-hs512

# ── Mail (SMTP) ───────────────────────────────────────────────────────────────
MAIL_HOST=smtp.ionos.co.uk
MAIL_PORT=587
MAIL_USERNAME=hello@certnow.co.uk
MAIL_PASSWORD=changeme

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@certnow.co.uk

# ── Object storage (MinIO / S3) ───────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=cert-now-docs

# ── Application ───────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8080
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*
APP_EMAIL_PROVIDER=smtp
APP_EMAIL_FROM=hello@certnow.co.uk
APP_EMAIL_REPLY_TO=admin@certnow.co.uk
APP_EMAIL_SUPPORT=admin@certnow.co.uk

# ── Third-party API keys (required — obtain from respective providers) ─────────
IDEAL_POSTCODES_API_KEY=your_ideal_postcodes_api_key_here
EPC_API_KEY=your_epc_api_key_here

# ── Slack (optional) ──────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
